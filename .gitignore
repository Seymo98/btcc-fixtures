# Secrets — NEVER commit
.env

# Local data (regenerable from API) — keep directory structure
data/*
!data/.gitkeep
!data/phase0_results/
data/phase0_results/*
!data/phase0_results/.gitkeep
!data/exports/
data/exports/*
!data/exports/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo
venv/
.venv/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDE
.vscode/
.idea/
*.swp
*.swo

# Generated outputs (large/frequent, rebuild from scripts)
# Uncomment the line below if you want to gitignore outputs too
# outputs/
